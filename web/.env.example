# Base URL of the Go API gateway. SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix) so it
# is never inlined into the browser bundle. The Next.js server uses it to call the
# gateway; the browser never sees it.
GATEWAY_URL=http://localhost:8080

# Object storage for product images (MinIO locally; S3/R2 in prod). All SERVER-SIDE.
#   S3_ENDPOINT         — how the Next server reaches the bucket to upload.
#   S3_PUBLIC_BASE_URL  — how the BROWSER reaches the bucket to load <img> (bucket root).
# These differ when Next runs in compose (server -> http://minio:9000, browser ->
# http://localhost:9000). For local `npm run dev` on the host they're both localhost.
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_BASE_URL=http://localhost:9000/product-images
S3_BUCKET=product-images
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
